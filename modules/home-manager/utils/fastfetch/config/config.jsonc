{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "modules": [
    /* {
        "type": "colors",
        "symbol": "circle",
    },*/
    "break",
    {
      "type": "title",
      "format": "                                {6}{7}{8}",
      "color": {
      "user": "cyan",
      "host": "blue",
      }
    },
    "break",
    {
      "type": "custom",
      "format": "┌────────────────────────────────────────────────────────────────────────┐" // `\u001b` is `\033`, or `\e`
      //"format": "                                    ",
    },
    "break",
    {
      "type": "os",
      "key": "    OS           ",
      "keyColor": "red",
    },
    {
    "type": "host",
      "key": "    Machine      ",
      "keyColor": "bright_red",
    },
    {
    "type": "kernel",
      "key": "    Kernel       ",
      "keyColor": "yellow",
    },
    {
    "type": "packages",
      "key": "    Packages     ",
      "keyColor": "green",
    },
    {
    "type": "shell",
      "key": "    Shell        ",
      "keyColor": "bright_green",
    },
    {
    "type": "de",
      "key": "    DE           ",
      "keyColor": "cyan",
    },
    {
    "type": "wm",
      "key": "    WM           ",
      "keyColor": "bright_cyan",
    },
    //"wmtheme",
    //"theme",
    //"icons",
    //"font",
    {
      "type": "terminalfont",
      "key": "    Font         ",
      "keyColor": "cyan",
    },
    {
    "type": "terminal",
      "key": "    Terminal     ",
      "keyColor": "bright_blue",
    },
    "break",
    {
    "type": "cpu",
      "key": "    CPU          ",
      "keyColor": "bright_cyan",
    },
    {
    "type": "gpu",
      "key": "    GPU          ",
      "keyColor": "bright_magenta",
    },
    {
    "type": "memory",
      "key": "    RAM          ",
      "keyColor": "italic_green",
    },
    {
    "type": "swap",
      "key": "    Swp          ",
      "keyColor": "bright_red",
    },
    {
    "type": "disk",
      "key": "    Disk         ",
      "keyColor": "red",
    },
    {
    "type": "localip",
      "key": "    IP           ",
      "keyColor": "dim_magenta",
    },
    "break",
    {
    "type": "uptime",
      "key": "    Uptime       ",
      "keyColor": "yellow",
    },
    {
      "type": "command",
      "key": "    Age          ",
      "keyColor": "yellow",
      "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days"
    },
    "break",
    {
      "type": "custom",
      "format": "└────────────────────────────────────────────────────────────────────────┘", // `\u001b` is `\033`, or `\e`
    },

    //"colors"
    /*{
      "type": "colors",
      "symbol": "circle",
    }*/
    {
      "type": "custom",
      "format": "                         \u001b[90m  \u001b[31m  \u001b[32m  \u001b[33m  \u001b[34m  \u001b[35m  \u001b[36m  \u001b[37m "
    },
  ],
  "display": {
    "separator": "➜   "
  },
  "logo": {

    "height" : 17,
    "width" : 35,
    "padding": {
      "right" : 2,
      "top" : 4,
    },
    "type" : "kitty-direct", // "kitty" also works
    "source" : "~/.config/fastfetch/nixos.png",
  },
}
